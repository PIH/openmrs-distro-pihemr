#############################################
# Global logging
#############################################

logging {
  level = "info"
}

#############################################
# Docker log ingestion (UNCHANGED)
#############################################

discovery.docker "linux" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_logs" {
  targets = discovery.docker.linux.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex        = "/(.*)"
    target_label = "container_name"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service_name"
  }

  rule {
    action       = "replace"
    replacement  = "docker"
    target_label = "job"
  }
}

loki.source.docker "docker_logs" {
  host    = "unix:///var/run/docker.sock"
  targets = discovery.relabel.docker_logs.output
  forward_to = [loki.process.docker.receiver]
}

loki.process "docker" {
  forward_to = [loki.write.local.receiver]

  stage.multiline {
    firstline = "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
  }

  stage.regex {
    expression = "(?i)(?P<level>trace|debug|info|warn|error|fatal)"
  }

  stage.labels {
    values = {
      level = "level"
    }
  }
}

#############################################
# Host log file ingestion (NEW, minimal)
# Mounted under /var/lib/alloy/data
#############################################

local.file_match "host_logs" {
  path_targets = [
    {
      "__path__" = "/var/lib/alloy/data/**/*.log",
      "job"      = "host_logs"
    }
  ]

  sync_period = "5s"
}

loki.source.file "host_file_logs" {
  targets       = local.file_match.host_logs.targets
  forward_to    = [loki.process.host_logs.receiver]
  tail_from_end = true
}

#############################################
# Host log processing (NO app parsing)
#############################################

loki.process "host_logs" {
  forward_to = [loki.write.local.receiver]

  # Keep behavior consistent with existing dashboard
  stage.regex {
    expression = "(?i)(?P<level>trace|debug|info|warn|error|fatal)"
  }

  stage.labels {
    values = {
      level = "level"
    }
  }
}

#############################################
# Loki output
#############################################

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}