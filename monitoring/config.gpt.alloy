#############################################
# Global logging
#############################################

logging {
  level = "info"
}

#############################################
# Docker log ingestion (existing behavior)
#############################################

discovery.docker "linux" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_logs" {
  targets = discovery.docker.linux.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex        = "/(.*)"
    target_label = "container_name"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service_name"
  }

  rule {
    action       = "replace"
    replacement  = "docker"
    target_label = "job"
  }
}

loki.source.docker "docker_logs" {
  host    = "unix:///var/run/docker.sock"
  targets = discovery.relabel.docker_logs.output
  forward_to = [loki.process.docker.receiver]
}

loki.process "docker" {
  forward_to = [loki.write.local.receiver]

  stage.multiline {
    firstline = "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
  }

  stage.regex {
    expression = "(?i)(?P<level>trace|debug|info|warn|error|fatal)"
  }

  stage.labels {
    values = {
      level = "level"
    }
  }
}

#############################################
# Host application log discovery
# (mounted into /var/lib/alloy/data)
#############################################

local.file_match "openmrs_logs" {
  path_targets = [
    {
      "__path__" = "/var/lib/alloy/data/openmrs/**/*.log",
      "job"      = "openmrs",
      "app"      = "openmrs"
    }
  ]
}

local.file_match "tomcat_logs" {
  path_targets = [
    {
      "__path__" = "/var/lib/alloy/data/tomcat/**/*.log",
      "job"      = "tomcat",
      "app"      = "tomcat9"
    }
  ]
}

local.file_match "mysql_logs" {
  path_targets = [
    {
      "__path__" = "/var/lib/alloy/data/mysql/**/*.log",
      "job"      = "mysql",
      "app"      = "mysql"
    }
  ]
}

#############################################
# Host application log sources
#############################################

loki.source.file "openmrs" {
  targets       = local.file_match.openmrs_logs.targets
  forward_to    = [loki.process.openmrs.receiver]
  tail_from_end = true
}

loki.source.file "tomcat" {
  targets       = local.file_match.tomcat_logs.targets
  forward_to    = [loki.process.tomcat.receiver]
  tail_from_end = true
}

loki.source.file "mysql" {
  targets       = local.file_match.mysql_logs.targets
  forward_to    = [loki.process.mysql.receiver]
  tail_from_end = true
}

#############################################
# OpenMRS log processing (Java / Log4j)
#############################################

loki.process "openmrs" {
  forward_to = [loki.write.local.receiver]

  stage.multiline {
    firstline = "^\\d{4}-\\d{2}-\\d{2}"
  }

  stage.regex {
    expression = "^(?P<timestamp>\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2},\\d+)\\s+(?P<level>[A-Z]+)\\s+\\[(?P<thread>[^\\]]+)\\]\\s+(?P<logger>[^ ]+)"
  }

  stage.labels {
    values = {
      level  = "level"
      logger = "logger"
      app    = "openmrs"
    }
  }
}

#############################################
# Tomcat 9 log processing
#############################################

loki.process "tomcat" {
  forward_to = [loki.write.local.receiver]

  stage.multiline {
    firstline = "^\\d{2}-[A-Za-z]{3}-\\d{4}"
  }

  stage.regex {
    expression = "^(?P<timestamp>\\d{2}-[A-Za-z]{3}-\\d{4} \\d{2}:\\d{2}:\\d{2}\\.\\d+)\\s+(?P<level>[A-Z]+)"
  }

  stage.labels {
    values = {
      level = "level"
      app   = "tomcat9"
    }
  }
}

#############################################
# MySQL / Percona 5.6 log processing
#############################################

loki.process "mysql" {
  forward_to = [loki.write.local.receiver]

  stage.regex {
    expression = "^(?P<timestamp>\\d{4}-\\d{2}-\\d{2}T[^ ]+)\\s+\\d+\\s+\\[(?P<level>[^\\]]+)\\]"
  }

  stage.labels {
    values = {
      level = "level"
      app   = "mysql"
    }
  }
}

#############################################
# Loki output
#############################################

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}